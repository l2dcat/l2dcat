{
  "problemMatcher": [
    {
      "owner": "l2dcat-gcc",
      "pattern": [
        {
          "regexp": "^(.+?):(\\d+):(\\d+):\\s+(warning|error|fatal error):\\s+(.*)$",
          "file": 1,
          "line": 2,
          "column": 3,
          "severity": 4,
          "message": 5
        }
      ]
    }
  ]
}
